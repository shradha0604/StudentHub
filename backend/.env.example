# ==============================
# OpenAI Configuration
# ==============================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# ==============================
# App Configuration
# ==============================
APP_ENV=development
LOG_LEVEL=INFO

# ==============================
# CORS
# ==============================
FRONTEND_ORIGIN=http://localhost:5173

# ==============================
# Request Limits
# ==============================
REQUEST_TIMEOUT_SECONDS=60
MAX_NOTES_LENGTH=20000
